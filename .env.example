# Hunter.io — required for email discovery
# Free tier: 25 searches/month — https://hunter.io/api
HUNTER_API_KEY=your_hunter_api_key_here

# Clearbit — optional, enables company metadata enrichment
# Free tier available — https://clearbit.com/docs
CLEARBIT_API_KEY=your_clearbit_api_key_here

# Throttling — seconds between API calls to stay within rate limits
RATE_LIMIT_DELAY=1.0

# Drop emails below this confidence score (0–100)
MIN_EMAIL_CONFIDENCE=60
